# Moodle LMS Configuration
MOODLE_URL=https://lms.vit.ac.in
MOODLE_USERNAME=your_username_here
MOODLE_PASSWORD=your_password_here

# ── LLM Provider ─────────────────────────────────
# Choose which LLM backend to use: "gemini" or "groq"
LLM_PROVIDER=gemini

# Google Gemini API Key (used when LLM_PROVIDER=gemini)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (used when LLM_PROVIDER=groq)
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Agent Settings
POLL_INTERVAL=30
PUBLISH_STATE=site
